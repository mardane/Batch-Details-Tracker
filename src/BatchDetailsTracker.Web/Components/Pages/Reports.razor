@page "/reports"
@using BatchDetailsTracker.Web.Models
@using BatchDetailsTracker.Web.Services
@inject BatchTrackerService BatchTrackerService

<PageTitle>Reports</PageTitle>

<h1>Performance snapshot</h1>
<p class="page-subtitle">A lightweight MVP report view for tracking weekly profit, averages, and operational trends.</p>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Total profit</div>
            <div class="stat-value">@TotalProfit.ToString("C")</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">This week</div>
            <div class="stat-value">@WeeklyProfit.ToString("C")</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Avg / batch</div>
            <div class="stat-value">@AveragePerBatch.ToString("C")</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Best batch</div>
            <div class="stat-value">@BestBatchValue.ToString("C")</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card app-card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Status breakdown</h2>

                @foreach (var item in StatusSummary)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@item.Label</span>
                            <span>@item.Count</span>
                        </div>
                        <div class="progress" role="progressbar" aria-label="@item.Label progress">
                            <div class="progress-bar @item.BarClass" style="width: @item.Percent%">@item.Percent%</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card app-card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Top opportunities</h2>

                @if (TopBatches.Count == 0)
                {
                    <p class="text-muted mb-0">Add some batches to unlock reporting.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var batch in TopBatches)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@batch.BatchName</div>
                                    <div class="small text-muted">@batch.StoreName • @batch.BatchDate.ToString("MMM dd") • @batch.ProfitPerHour.ToString("C")/hr</div>
                                </div>
                                <span class="fw-semibold">@batch.TotalEarnings.ToString("C")</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<BatchRecord> Batches = [];

    protected override async Task OnInitializedAsync()
    {
        Batches = (await BatchTrackerService.GetBatchesAsync()).ToList();
    }

    private decimal TotalProfit => Batches.Where(batch => batch.Status != BatchStatus.Cancelled).Sum(batch => batch.TotalEarnings);
    private decimal WeeklyProfit => Batches.Where(batch => batch.BatchDate >= DateTime.Today.AddDays(-6) && batch.Status != BatchStatus.Cancelled).Sum(batch => batch.TotalEarnings);
    private decimal AveragePerBatch => Batches.Count == 0 ? 0 : TotalProfit / Batches.Count;
    private decimal BestBatchValue => Batches.Count == 0 ? 0 : Batches.Max(batch => batch.TotalEarnings);

    private List<StatusItem> StatusSummary =>
    [
        BuildStatusItem("Completed", BatchStatus.Completed, "bg-success"),
        BuildStatusItem("Active", BatchStatus.Active, "bg-primary"),
        BuildStatusItem("Cancelled", BatchStatus.Cancelled, "bg-secondary")
    ];

    private List<BatchRecord> TopBatches => Batches
        .Where(batch => batch.Status != BatchStatus.Cancelled)
        .OrderByDescending(batch => batch.TotalEarnings)
        .Take(5)
        .ToList();

    private StatusItem BuildStatusItem(string label, BatchStatus status, string barClass)
    {
        var count = Batches.Count(batch => batch.Status == status);
        var percent = Batches.Count == 0 ? 0 : (int)Math.Round(count * 100d / Batches.Count);
        return new StatusItem(label, count, percent, barClass);
    }

    private sealed record StatusItem(string Label, int Count, int Percent, string BarClass);
}
