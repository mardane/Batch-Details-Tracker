@page "/"
@rendermode InteractiveServer
@inject BatchTrackerService BatchTrackerService

<PageTitle>Dashboard</PageTitle>

<div class="app-hero mb-4">
    <div>
        <span class="hero-badge">MVP • Responsive Web</span>
        <h1 class="mb-2">Instacart Batch Tracker</h1>
        <p class="mb-0">Track daily progress, profit, and batch details from one clean dashboard that works on Windows, Android, and iPhone browsers.</p>
    </div>
    <div class="d-flex flex-column flex-sm-row gap-2">
        <a class="btn btn-light btn-lg" href="/batches">Log today’s batch</a>
        <a class="btn btn-outline-light btn-lg" href="/reports">View reports</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Total profit</div>
            <div class="stat-value">@TotalProfit.ToString("C")</div>
            <div class="text-muted small">Across all tracked batches</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">This week</div>
            <div class="stat-value">@WeeklyProfit.ToString("C")</div>
            <div class="text-muted small">Last 7 days performance</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Active batches</div>
            <div class="stat-value">@ActiveCount</div>
            <div class="text-muted small">Currently in progress</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Avg / batch</div>
            <div class="stat-value">@AveragePerBatch.ToString("C")</div>
            <div class="text-muted small">Average earnings per run</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-7">
        <div class="card app-card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2 class="h5 mb-1">Recent batches</h2>
                        <p class="text-muted mb-0">Quick view of your latest Instacart activity.</p>
                    </div>
                </div>

                @if (RecentBatches.Count == 0)
                {
                    <p class="text-muted mb-0">No batches recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Batch</th>
                                    <th>Status</th>
                                    <th>Profit</th>
                                    <th>Per hour</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var batch in RecentBatches)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@batch.BatchName</div>
                                            <div class="small text-muted">@batch.StoreName • @batch.BatchDate.ToString("MMM dd")</div>
                                        </td>
                                        <td>
                                            <span class="status-pill @GetStatusClass(batch.Status)">@batch.Status</span>
                                        </td>
                                        <td class="fw-semibold">@batch.TotalEarnings.ToString("C")</td>
                                        <td>@batch.ProfitPerHour.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card app-card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Today’s progress</h2>
                <p class="text-muted">@TodayProgressText</p>

                <div class="progress mb-3" role="progressbar" aria-label="Today progress">
                    <div class="progress-bar bg-success" style="width: @ProgressPercent%">@ProgressPercent%</div>
                </div>

                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span>Completed today</span>
                        <strong>@CompletedToday</strong>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span>Total tracked today</span>
                        <strong>@TodayTotal</strong>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span>Mobile-ready UI</span>
                        <strong>Yes</strong>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    private List<BatchRecord> Batches = [];

    protected override async Task OnInitializedAsync()
    {
        Batches = (await BatchTrackerService.GetBatchesAsync()).ToList();
    }

    private List<BatchRecord> RecentBatches => Batches.Take(5).ToList();
    private decimal TotalProfit => Batches.Where(batch => batch.Status != BatchStatus.Cancelled).Sum(batch => batch.TotalEarnings);
    private decimal WeeklyProfit => Batches.Where(batch => batch.BatchDate >= DateTime.Today.AddDays(-6) && batch.Status != BatchStatus.Cancelled).Sum(batch => batch.TotalEarnings);
    private int ActiveCount => Batches.Count(batch => batch.Status == BatchStatus.Active);
    private decimal AveragePerBatch => Batches.Count == 0 ? 0 : TotalProfit / Batches.Count;
    private int CompletedToday => Batches.Count(batch => batch.BatchDate.Date == DateTime.Today && batch.Status == BatchStatus.Completed);
    private int TodayTotal => Batches.Count(batch => batch.BatchDate.Date == DateTime.Today);
    private int ProgressPercent => TodayTotal == 0 ? 0 : (int)Math.Round(CompletedToday * 100d / TodayTotal);
    private string TodayProgressText => TodayTotal == 0
        ? "No batches logged for today yet — add your first one to start tracking."
        : $"{CompletedToday} of {TodayTotal} batch(es) completed today.";

    private static string GetStatusClass(BatchStatus status) => status switch
    {
        BatchStatus.Completed => "status-completed",
        BatchStatus.Active => "status-active",
        _ => "status-cancelled"
    };
}
